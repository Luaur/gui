-- [ WEBHOOK FUNCTION ] --
local function sendWebhook(title, description, color, fields)
    if WebhookURL == "" then return end
    
    local data = {
        ["username"] = "KemplongXD Telemetry",
        ["avatar_url"] = "https://i.imgur.com/AfFp7pu.png",
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = description,
            ["color"] = color,
            ["fields"] = fields or {},
            ["footer"] = {
                ["text"] = "SYS_LOG | " .. os.date("%Y-%m-%d %H:%M:%S")
            }
        }}
    }
    
    task.spawn(function()
        pcall(function()
            local requestFunc = syn and syn.request or http_request or request or fluxus and fluxus.request
            if requestFunc then
                requestFunc({
                    Url = WebhookURL,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = HttpService:JSONEncode(data)
                })
            end
        end)
    end)
end

-- [ PENGUMPULAN DATA DINAMIS ] --
local function getPing()
    local pingStr = Stats.Network:FindFirstChild("ServerStatsItem") and Stats.Network.ServerStatsItem:FindFirstChild("Data Ping") and Stats.Network.ServerStatsItem["Data Ping"]:GetValueString() or "0"
    return tonumber(pingStr:match("%d+")) or 0
end

local function getMemory()
    return tostring(math.floor(Stats:GetTotalMemoryUsageMb())) .. " MB"
end

local function getLeaderstats()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    if not ls then return "NULL" end
    local stats = {}
    for _, stat in pairs(ls:GetChildren()) do
        table.insert(stats, stat.Name .. ": " .. tostring(stat.Value))
    end
    return table.concat(stats, " | ")
end

-- [ MONITORING & AUTO-RECONNECT LOGIC ] --
local function startMonitoring()
    local promptOverlay = CoreGui:FindFirstChild("RobloxPromptGui")
    if promptOverlay and promptOverlay:FindFirstChild("promptOverlay") then
        promptOverlay.promptOverlay.ChildAdded:Connect(function(child)
            if child.Name == "ErrorPrompt" then
                sendWebhook("[SYS_ERR] CONNECTION_LOST", "Client terputus dari host. Menginisiasi protokol re-koneksi.", 16711680, {
                    {["name"] = "TARGET_NODE", ["value"] = "```" .. game.JobId .. "```", ["inline"] = false}
                })
                task.wait(5)
                TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
            end
        end)
    end

    local lastAlert = 0
    RunService.RenderStepped:Connect(function(deltaTime)
        local fps = 1 / deltaTime
        if fps < 15 and (tick() - lastAlert) > 120 then
            sendWebhook("[WARN] PERF_DEGRADATION", "Framerate berada di bawah ambang batas toleransi.", 16753920, {
                {["name"] = "CURR_FPS", ["value"] = tostring(math.floor(fps)), ["inline"] = true},
                {["name"] = "MEM_USAGE", ["value"] = getMemory(), ["inline"] = true}
            })
            lastAlert = tick()
        end
    end)

    task.spawn(function()
        while task.wait(5) do
            local ping = getPing()
            if ping > 400 and (tick() - lastAlert) > 120 then
                sendWebhook("[WARN] NET_LATENCY", "Lonjakan latensi jaringan terdeteksi.", 16753920, {
                    {["name"] = "CURR_PING", ["value"] = tostring(ping) .. " ms", ["inline"] = true}
                })
                lastAlert = tick()
            end
        end
    end)

    task.spawn(function()
        while task.wait(StatusInterval) do
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            
            local coords = hrp and string.format("%.1f, %.1f, %.1f", hrp.Position.X, hrp.Position.Y, hrp.Position.Z) or "N/A"
            local wSpeed = humanoid and tostring(humanoid.WalkSpeed) or "N/A"
            
            local fields = {
                {["name"] = "USER_DATA", ["value"] = "Username: " .. LocalPlayer.Name .. "\nUser ID: " .. LocalPlayer.UserId, ["inline"] = false},
                {["name"] = "LOCATION", ["value"] = coords, ["inline"] = true},
                {["name"] = "WALKSPEED", ["value"] = wSpeed, ["inline"] = true},
                {["name"] = "LEADERSTATS", ["value"] = getLeaderstats(), ["inline"] = false}
            }
            
            sendWebhook("[INFO] ROUTINE_STATUS", "Pembaruan telemetri berkala.", 32768, fields)
        end
    end)
end

