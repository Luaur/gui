local st = {SW=false, LP=false, WW=false, WH=false}
local function fBtn(txt, y, k, cb)
    local b = mk("TextButton", {Size=UDim2.new(0.85,0,0,40), Position=UDim2.new(0.075,0,0,y), Text="  "..txt, Font=Enum.Font.GothamSemibold, TextSize=13, BackgroundColor3=Color3.fromRGB(35,35,42), TextColor3=Color3.fromRGB(210,210,210), TextXAlignment=0, AutoButtonColor=false, Parent=cnt})
    mk("UICorner", {CornerRadius=UDim.new(0,6), Parent=b})
    local sk = mk("UIStroke", {Color=Color3.fromRGB(60,60,70), ApplyStrokeMode=0, Parent=b})
    local id = mk("Frame", {Size=UDim2.new(0,10,0,10), Position=UDim2.new(1,-20,0.5,-5), BackgroundColor3=Color3.fromRGB(80,80,90), Parent=b})
    mk("UICorner", {CornerRadius=UDim.new(1,0), Parent=id})
    b.MouseEnter:Connect(function() T:Create(sk,TweenInfo.new(0.2),{Color=Color3.fromRGB(100,100,120)}):Play() end)
    b.MouseLeave:Connect(function() T:Create(sk,TweenInfo.new(0.2),{Color=Color3.fromRGB(60,60,70)}):Play() end)
    b.MouseButton1Click:Connect(function()
        if k then st[k] = not st[k] end
        if cb then cb() end
        if k then
            T:Create(b,TweenInfo.new(0.2),{BackgroundColor3=st[k] and Color3.fromRGB(40,50,65) or Color3.fromRGB(35,35,42), TextColor3=st[k] and Color3.new(1,1,1) or Color3.fromRGB(210,210,210)}):Play()
            T:Create(id,TweenInfo.new(0.2),{BackgroundColor3=st[k] and Color3.fromRGB(45,150,255) or Color3.fromRGB(80,80,90)}):Play()
        else
            T:Create(b,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(40,50,65), TextColor3=Color3.new(1,1,1)}):Play()
            T:Create(id,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(0,255,100)}):Play()
            task.delay(0.3, function() T:Create(b,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(35,35,42), TextColor3=Color3.fromRGB(210,210,210)}):Play() T:Create(id,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(80,80,90)}):Play() end)
        end
    end)
end

