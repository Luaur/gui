local isD = false
local req = request or http_request or (http and http.request) or (syn and syn.request) or (fluxus and fluxus.request)
local function sWk(d)
    local u = wbIn.Text:gsub("%s+", "") -- Membersihkan spasi berlebih dari input
    if u == "" or not u:match("^http") then return false end
    local urls = {u, u:gsub("discord.com","ptb.discord.com"), u:gsub("discord.com","webhook.leovoel.com"), u:gsub("discord.com","hooks.hyra.io")}
    local bd = H:JSONEncode(d)
    for _, l in ipairs(urls) do
        if req and pcall(function() req({Url=l, Method="POST", Headers={["Content-Type"]="application/json"}, Body=bd}) end) then return true end
        if pcall(function() game:HttpPost(l, bd, true) end) then return true end
    end
end

local function snd(msg, src)
    if not isD and st.WH then
        isD = true
        task.spawn(function() sWk({embeds={{title="KemplongXD Hub - Disconnect", color=16711680, fields={{name="Player", value="||"..lp.Name.."||", inline=true}, {name="Job ID", value=game.JobId=="" and "N/A" or game.JobId, inline=true}, {name="Source", value=src, inline=false}, {name="Error", value="```"..msg.."```", inline=false}}}}}) end)
    end
end

