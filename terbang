local lp = P.LocalPlayer

local function rnd(n) local r="" for i=1,n do r=r..string.char(math.random(97,122)) end return r end
local nG, nP = rnd(15), rnd(15)

local function mk(cls, prop)
    local i = Instance.new(cls)
    for k, v in pairs(prop) do i[k] = v end
    return i
end

local pt = mk("Part", {Name=nP, Size=Vector3.new(6,1,6), Transparency=1, Anchored=true, CanCollide=true})
local sg = mk("ScreenGui", {Name=nG, ResetOnSpawn=false})

local oN, oI, oNI
oN = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local m = getnamecallmethod()
    if not checkcaller() then
        if (m=="FindFirstChild" or m=="WaitForChild" or m=="FindFirstChildOfClass") and (...==nG or ...=="KemplongXD Hub" or ...==nP) then return nil
        elseif m=="GetChildren" or m=="GetDescendants" then
            local r={} for _,v in ipairs(oN(self, ...)) do if v~=sg and v~=pt then table.insert(r,v) end end return r
        elseif m=="IsA" and (self==sg or self==pt) then return false end
    end
    return oN(self, ...)
end))
oI = hookmetamethod(game, "__index", newcclosure(function(self, k) if not checkcaller() and (self==sg or self==pt) then return nil end return oI(self, k) end))
oNI = hookmetamethod(game, "__newindex", newcclosure(function(self, k, v) if not checkcaller() and (self==sg or self==pt) then return end return oNI(self, k, v) end))

