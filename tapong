local function updateTabs(active)
    local btns = {Info = InfoTabBtn, Fishing = FishingTabBtn, Sell = SellTabBtn, Teleport = TeleportTabBtn, Items = ItemsTabBtn}
    for name, btn in pairs(btns) do
        btn.BackgroundColor3 = active == name and Color3.fromRGB(60, 60, 60) or Color3.fromRGB(42, 42, 42)
        btn.TextColor3 = active == name and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 160, 160)
        btn.Font = active == name and Enum.Font.GothamBold or Enum.Font.GothamMedium
    end
    InfoPage.Visible = active == "Info"
    FishingPage.Visible = active == "Fishing"
    SellPage.Visible = active == "Sell"
    TeleportPage.Visible = active == "Teleport"
    ItemsPage.Visible = active == "Items"
