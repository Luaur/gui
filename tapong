-- Dynamic Tool ID Fetcher
local function getDynamicToolId()
    local userIdStr = tostring(Player.UserId)
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        local match = string.match(child.Name, "FishingRod_" .. userIdStr .. "_(.-)_ThrowState")
        if match then return match end
    end
    return nil
end

local isInstant = false
local isAutoSelling = false
local isAutoStone = false

local function performFishingLoop()
    local throwEvent = ReplicatedStorage:FindFirstChild("Fishing_RemoteThrow")
    local fishingFolder = ReplicatedStorage:FindFirstChild("Fishing")
    
    local reelRemote = nil
    local cancelRemote = nil
    
    if fishingFolder and fishingFolder:FindFirstChild("ToServer") then
        reelRemote = fishingFolder.ToServer:FindFirstChild("ReelFinished")
        cancelRemote = fishingFolder.ToServer:FindFirstChild("CancelPendingBite")
    end

    while isInstant do
        local currentToolId = getDynamicToolId()

        if not currentToolId then
            StatusLabel.Text = "Standby: Please equip your rod..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 159, 10)
            task.wait(1)
            continue
        end

        StatusLabel.Text = "Mode: INSTANT | ID: " .. string.sub(currentToolId, 1, 10) .. "..."
        StatusLabel.TextColor3 = Color3.fromRGB(48, 209, 88)

        local multiCount = tonumber(MultiInput.Text) or 10
        local delayTime = tonumber(DelayInput.Text) or 4

        for i = 1, multiCount do
            if not isInstant then break end
            
            -- FIX: Berurutan, tidak di-spawn bersamaan agar server tidak nge-bug
            if throwEvent then
                throwEvent:FireServer(0.93745006500285, currentToolId)
            end
            
            task.wait(delayTime)
            
            if reelRemote then
                reelRemote:FireServer({
                    duration = 2.7480297389993,
                    result = "SUCCESS",
                    insideRatio = 0.8
                }, currentToolId)
            end
            
            if cancelRemote then
                cancelRemote:FireServer(currentToolId)
            end
            
            sessionCaught = sessionCaught + 1
            CaughtLabel.Text = "Session Caught: " .. tostring(sessionCaught)
            
            -- Jeda kecil antar lemparan agar rate limit aman
            task.wait(0.2) 
        end
        
        task.wait(0.5)
    end
end

local function performAutoSell()
    while isAutoSelling do
        local sellDelay = tonumber(SellDelayInput.Text) or 10
        local sellUnderVal = tonumber(SellDropdownBtn.Text) or 1000
        
        local econFolder = ReplicatedStorage:FindFirstChild("Economy")
        if econFolder and econFolder:FindFirstChild("ToServer") and econFolder.ToServer:FindFirstChild("SellUnder") then
            econFolder.ToServer.SellUnder:FireServer(sellUnderVal)
            SellStatusLabel.Text = "Status: Selling items under " .. sellUnderVal
            SellStatusLabel.TextColor3 = Color3.fromRGB(48, 209, 88)
        else
            SellStatusLabel.Text = "Status: Remote 'SellUnder' not found!"
            SellStatusLabel.TextColor3 = Color3.fromRGB(255, 95, 86)
        end
        task.wait(sellDelay)
    end
end

local function performAutoStone()
    local luckyFolder = ReplicatedStorage:FindFirstChild("LuckyStone")
    local activateRemote = nil
    if luckyFolder and luckyFolder:FindFirstChild("ToServer") then
        activateRemote = luckyFolder.ToServer:FindFirstChild("ActivateStone")
    end

    local stoneTypes = {"GREEN_STONE", "YELLOW_STONE", "BLACK_STONE"}

    while isAutoStone do
        if activateRemote then
            local currentToolId = getDynamicToolId()
            if currentToolId then
                local amount = tonumber(StoneAmtInput.Text) or 1
                for _, sType in ipairs(stoneTypes) do
                    for i = 1, amount do
                        activateRemote:FireServer(currentToolId, sType)
                        task.wait(0.2)
                    end
                end
                StoneStatusLabel.Text = "Auto Stone: Active ("..amount.." Each)"
                StoneStatusLabel.TextColor3 = Color3.fromRGB(48, 209, 88)
            else
                StoneStatusLabel.Text = "Auto Stone: Please equip rod!"
                StoneStatusLabel.TextColor3 = Color3.fromRGB(255, 159, 10)
            end
        else
            StoneStatusLabel.Text = "Auto Stone: Remote not found!"
            StoneStatusLabel.TextColor3 = Color3.fromRGB(255, 95, 86)
        end
        local delayTime = tonumber(StoneDelayInput.Text) or 300
        task.wait(delayTime)
    end
end

