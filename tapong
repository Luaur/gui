for _, val in ipairs(sellOptions) do
    local optBtn = Instance.new("TextButton")
    optBtn.Size = UDim2.new(1, 0, 0, 25)
    optBtn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
    optBtn.BackgroundTransparency = 1
    optBtn.TextColor3 = Color3.fromRGB(230, 230, 230)
    optBtn.Font = Enum.Font.GothamMedium
    optBtn.TextSize = 12
    optBtn.Text = tostring(val)
    optBtn.ZIndex = 6
    optBtn.Parent = SellDropdownList
    optBtn.MouseButton1Click:Connect(function() SellDropdownBtn.Text = tostring(val) SellDropdownList.Visible = false end)
    optBtn.MouseEnter:Connect(function() optBtn.BackgroundTransparency = 0 end)
    optBtn.MouseLeave:Connect(function() optBtn.BackgroundTransparency = 1 end)
end

